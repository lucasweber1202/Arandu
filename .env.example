# Arandu — variáveis de ambiente

# Contato público
ARANDU_WHATSAPP_NUMBER=
ARANDU_CONTACT_EMAIL=
ARANDU_SITE_URL=
ARANDU_WRITE_TEST_URL=
ARANDU_BRAND_READY=false
ARANDU_COMMERCIAL_READY=false
ARANDU_PILOT_ENABLED=false
ARANDU_PILOT_APPROVED=false
ARANDU_PILOT_ACCESS_CODE=
ARANDU_PILOT_SECRET=
ARANDU_DISTRIBUTED_RATE_LIMIT=true
ARANDU_PRIVACY_CONTACT_EMAIL=
ARANDU_ERROR_MONITORING_READY=false
ARANDU_BACKUP_VERIFIED_AT=

# Supabase usado pela função consolidada api/[...path].js
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Token privado para painel administrativo
# Use um valor longo, aleatório e diferente de senhas pessoais.
ARANDU_ADMIN_TOKEN=

# Futuro envio de e-mail
RESEND_API_KEY=

# Futuro analytics
PUBLIC_ANALYTICS_ID=
