# Arandu — variáveis de ambiente

# Contato público
ARANDU_WHATSAPP_NUMBER=55DDDNUMERO
ARANDU_CONTACT_EMAIL=ola@arandu.art
ARANDU_SITE_URL=https://arandu.art

# Supabase usado pela função consolidada api/[...path].js
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=chave_publica_anon
SUPABASE_SERVICE_ROLE_KEY=chave_service_role_apenas_servidor

# Token privado para painel administrativo
# Use um valor longo, aleatório e diferente de senhas pessoais.
ARANDU_ADMIN_TOKEN=troque-por-um-token-longo-e-privado

# Futuro envio de e-mail
RESEND_API_KEY=

# Futuro analytics
PUBLIC_ANALYTICS_ID=
