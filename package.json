{
  "name": "arandu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "vercel-build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "node scripts/check-static.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:production": "node scripts/production-check.mjs",
    "check:quality": "node scripts/arandu-quality-gate.mjs",
    "check:inventory": "node scripts/page-inventory.mjs",
    "check:all": "npm run check && npm run check:links && npm run check:production && npm run check:quality && npm run check:inventory",
    "predeploy": "npm run build && npm run check:all"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.2.0",
    "vite": "^5.4.0",
    "typescript": "^5.6.0"
  },
  "devDependencies": {}
}
