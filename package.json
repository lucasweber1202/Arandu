{
  "name": "arandu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/copy-runtime-assets.mjs",
    "vercel-build": "npm run build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "node scripts/check-static.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:runtime:local": "node scripts/check-runtime-site.mjs http://localhost:4173",
    "check:runtime:prod": "node scripts/check-runtime-site.mjs https://arandu-bice.vercel.app",
    "check:production": "node scripts/production-check.mjs",
    "check:quality": "node scripts/arandu-quality-gate.mjs",
    "check:inventory": "node scripts/page-inventory.mjs",
    "check:data": "node scripts/check-data.mjs",
    "check:backend": "node scripts/check-backend.mjs && node scripts/check-api-modules.mjs",
    "check:security": "node scripts/check-auth-security.mjs && node scripts/test-auth-api.mjs",
    "check:commercial": "node scripts/check-commercial-docs.mjs",
    "check:ux": "node scripts/check-ux-launch.mjs",
    "check:ready": "node scripts/check-ready.mjs",
    "check:live": "node scripts/check-live-production.mjs",
    "check:live:prod": "node scripts/check-live-production.mjs https://arandu-bice.vercel.app",
    "check:all": "npm run check && npm run check:links && npm run check:production && npm run check:quality && npm run check:inventory && npm run check:data && npm run check:backend && npm run check:security && npm run check:commercial && npm run check:ux",
    "seed:supabase": "node scripts/seed-supabase.mjs",
    "seed:supabase:dry": "node scripts/seed-supabase.mjs --dry-run",
    "predeploy": "npm run build && npm run check:all"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.2.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.3"
  }
}
