{
  "name": "arandu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/copy-runtime-assets.mjs",
    "vercel-build": "npm run build",
    "preview": "vite preview --host 0.0.0.0",
    "serve:test": "node scripts/serve-dist.mjs",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "check": "node scripts/check-static.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:runtime:local": "node scripts/check-runtime-site.mjs http://localhost:4173",
    "check:runtime:prod": "node scripts/check-runtime-site.mjs",
    "check:production": "node scripts/production-check.mjs",
    "check:quality": "node scripts/arandu-quality-gate.mjs",
    "check:inventory": "node scripts/page-inventory.mjs",
    "check:data": "node scripts/check-data.mjs",
    "check:catalog": "node scripts/check-catalog-readiness.mjs && node scripts/check-catalog-contract.mjs && node scripts/test-catalog-api.mjs && node scripts/test-collections-api.mjs",
    "check:catalog:release": "node scripts/check-catalog-readiness.mjs --require-verified",
    "check:migrations": "node scripts/check-migrations.mjs",
    "check:routes": "node scripts/check-public-routes.mjs && node scripts/check-page-surface.mjs",
    "check:domain": "node scripts/check-domain-config.mjs",
    "check:domain:release": "node scripts/check-domain-config.mjs --require-ready",
    "check:supabase:write": "node scripts/test-supabase-write.mjs",
    "check:pilot": "node scripts/check-pilot-readiness.mjs && node scripts/check-pilot-security.mjs && node scripts/test-pilot-api.mjs",
    "check:platform": "node scripts/check-platform-hardening.mjs && node scripts/test-platform-api.mjs",
    "check:platform:release": "node scripts/check-platform-release.mjs",
    "check:pilot:release": "node scripts/check-pilot-readiness.mjs --require-ready",
    "check:backend": "node scripts/check-backend.mjs && node scripts/check-api-modules.mjs",
    "check:security": "node scripts/check-auth-security.mjs && node scripts/test-auth-api.mjs",
    "check:commercial": "node scripts/check-commercial-docs.mjs",
    "check:commercial:release": "node scripts/check-commercial-release.mjs --require-ready",
    "check:ux": "node scripts/check-ux-launch.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:seo:dist": "node scripts/check-seo.mjs --dist",
    "check:readability": "node scripts/check-readability.mjs",
    "check:env": "node scripts/check-production-env.mjs",
    "check:env:release": "node scripts/check-production-env.mjs --require-ready",
    "check:evidence": "node scripts/check-release-evidence.mjs",
    "check:evidence:release": "node scripts/check-release-evidence.mjs --require-ready",
    "check:catalog:intake": "node scripts/test-catalog-intake.mjs",
    "check:ready": "node scripts/check-ready.mjs",
    "check:live": "node scripts/check-live-production.mjs",
    "check:live:prod": "node scripts/check-live-production.mjs",
    "check:all": "npm run check && npm run check:links && npm run check:production && npm run check:quality && npm run check:inventory && npm run check:data && npm run check:catalog && npm run check:catalog:intake && npm run check:migrations && npm run check:routes && npm run check:domain && npm run check:pilot && npm run check:platform && npm run check:backend && npm run check:security && npm run check:commercial && node scripts/check-commercial-release.mjs && npm run check:ux && npm run check:seo && npm run check:readability && npm run check:env && npm run check:evidence",
    "release:status": "node scripts/release-status.mjs",
    "release:check": "node scripts/release-status.mjs --require-ready",
    "migrations:bundle": "node scripts/build-supabase-migration-bundle.mjs",
    "seed:supabase": "node scripts/seed-supabase.mjs",
    "seed:supabase:dry": "node scripts/seed-supabase.mjs --dry-run",
    "predeploy": "npm run build && npm run check:all && npm run check:env:release && npm run check:evidence:release && npm run check:catalog:release && npm run check:domain:release && npm run check:commercial:release && npm run check:pilot:release && npm run check:platform:release"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.2.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
